# MACE Potential Simulation: Li-Ga-Cl-F system
# Optimized for DCU performance

units           metal
dimension       3
boundary        p p p
atom_style      atomic 
atom_modify     map yes
newton          on

# Neighbor settings
neighbor        1.0 bin
neigh_modify    every 1 delay 0 check yes

# System Definition
read_data       OOD-SR.data
# Potential Settings (MACE)
# Note: 'no_domain_decomposition' means you should run this with 1 MPI process (single DCU card)
pair_style      mace no_domain_decomposition
pair_coeff      * * mace-mpa-0-medium.model-lammps.pt Li Ga Cl F

# Initial velocities
velocity        all create 298 4928459 rot yes dist gaussian

# Simulation Parameters
variable        dt equal 0.001       # 1fs
timestep        ${dt}

# Thermodynamic Output - Frequency increased to 100 to avoid DCU performance bottleneck
thermo          10
thermo_style    custom step temp press pe ke etotal 

# Fixes: NVT Ensemble
fix             1 all nvt temp 298 298 $(100*dt)

# Execution
run             100

